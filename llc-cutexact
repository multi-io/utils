#!/usr/bin/env python3
# usage: llc-cutexact input.mp4 segments.csv output.mp4
#
# segments.csv has this format:
#
# Start,End,Name
# 33.411793,41.258333333333336,some name
# 214.625,234.20833333333334,names
# 283.324,299.5833333333333,are
# 301.25,327.433824,ignored
#
# cuts those segments from input.mp4, concatenates them into output.mp4
# 
# the csv format corresponds to LossleesCut's (llc's) csv export (File/Export Project/Timestamps (CSV)),
# so you can use this script to cut like llc, except at exact frame boundaries (which means it's no longer lossless).

import argparse
import csv
import os
import shutil
import subprocess
import sys
import tempfile


def run(cmd):
    print("Running:", " ".join(cmd))
    subprocess.run(cmd, check=True)


def parse_segments(csv_path):
    segments = []

    with open(csv_path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)

        required = {"Start", "End"}
        if not required.issubset(reader.fieldnames or set()):
            raise ValueError(
                f"CSV must contain headers: {', '.join(sorted(required))}"
            )

        for i, row in enumerate(reader, start=1):
            try:
                start = float(row["Start"])
                end = float(row["End"])
            except (TypeError, ValueError):
                raise ValueError(f"Invalid Start/End on row {i}: {row}")

            if start < 0 or end < 0:
                raise ValueError(f"Negative timestamp on row {i}: {row}")

            if end <= start:
                raise ValueError(
                    f"End must be greater than Start on row {i}: {row}"
                )

            segments.append((start, end))

    if not segments:
        raise ValueError("No valid segments found in CSV")

    return segments


def ffmpeg_concat(video_path, segments, output_path):
    ffmpeg = shutil.which("ffmpeg")
    if not ffmpeg:
        raise RuntimeError(
            "ffmpeg not found on PATH. Please install ffmpeg first."
        )

    with tempfile.TemporaryDirectory() as tmpdir:
        part_files = []

        for idx, (start, end) in enumerate(segments):
            duration = end - start
            part_path = os.path.join(tmpdir, f"part_{idx:04d}.mp4")
            part_files.append(part_path)

            cmd = [
                ffmpeg,
                "-y",
                "-i",
                video_path,
                "-ss",
                str(start),
                "-t",
                str(duration),
                "-c:v",
                "libx264",
                "-preset",
                "medium",
                "-crf",
                "18",
                "-c:a",
                "aac",
                "-movflags",
                "+faststart",
                part_path,
            ]
            run(cmd)

        concat_list = os.path.join(tmpdir, "concat.txt")
        with open(concat_list, "w", encoding="utf-8") as f:
            for part in part_files:
                f.write(f"file '{part}'\n")

        cmd = [
            ffmpeg,
            "-y",
            "-f",
            "concat",
            "-safe",
            "0",
            "-i",
            concat_list,
            "-c",
            "copy",
            output_path,
        ]
        run(cmd)


def main():
    parser = argparse.ArgumentParser(
        description=(
            "Cut video segments from an MP4 using a CSV of Start/End times, "
            "then concatenate them into one output video."
        )
    )
    parser.add_argument("input_video", help="Path to input MP4 file")
    parser.add_argument("input_csv", help="Path to CSV file")
    parser.add_argument("output_video", help="Path to output MP4 file")
    args = parser.parse_args()

    if not os.path.isfile(args.input_video):
        print(f"Input video not found: {args.input_video}", file=sys.stderr)
        sys.exit(1)

    if not os.path.isfile(args.input_csv):
        print(f"Input CSV not found: {args.input_csv}", file=sys.stderr)
        sys.exit(1)

    try:
        segments = parse_segments(args.input_csv)
        ffmpeg_concat(args.input_video, segments, args.output_video)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    print(f"Done. Output written to: {args.output_video}")


if __name__ == "__main__":
    main()
